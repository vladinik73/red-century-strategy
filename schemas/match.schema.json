{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Match State (v4.28)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "turn",
    "players",
    "map",
    "cities",
    "units",
    "diplomacy",
    "victory",
    "events"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "match_id",
        "mode",
        "seed",
        "created_at_utc"
      ],
      "properties": {
        "match_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]{16}$"
        },
        "mode": {
          "type": "string",
          "enum": [
            "PvE",
            "PvP",
            "AsyncPvP"
          ]
        },
        "seed": {
          "type": "integer"
        },
        "created_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "ruleset": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source_of_truth_version": {
              "type": "string"
            },
            "git_commit": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_index",
        "round_index",
        "active_player_id",
        "turn_order_player_ids"
      ],
      "properties": {
        "turn_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Increments after each civilization completes its turn."
        },
        "round_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Increments after all alive civilizations complete a turn."
        },
        "active_player_id": {
          "type": "string"
        },
        "turn_order_player_ids": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        },
        "alive_player_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ended_player_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "players": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "player.schema.json"
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "tiles_flat"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "enum": [
            80
          ]
        },
        "height": {
          "type": "integer",
          "enum": [
            80
          ]
        },
        "tiles_flat": {
          "type": "array",
          "minItems": 6400,
          "maxItems": 6400,
          "items": {
            "$ref": "tile.schema.json"
          },
          "description": "Flat array; index = y*width + x"
        }
      }
    },
    "cities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "city_id",
          "x",
          "y",
          "owner_player_id",
          "is_capital",
          "level",
          "defense_level",
          "integration_turns_left",
          "territory_tile_indices"
        ],
        "properties": {
          "city_id": {
            "type": "string"
          },
          "x": {
            "type": "integer",
            "minimum": 0,
            "maximum": 79
          },
          "y": {
            "type": "integer",
            "minimum": 0,
            "maximum": 79
          },
          "owner_player_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "null = neutral city"
          },
          "is_capital": {
            "type": "boolean"
          },
          "level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "defense_level": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2
          },
          "integration_turns_left": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "sieged": {
            "type": "boolean"
          },
          "disruption_turns_left": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2
          },
          "territory_radius": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "default": 1,
            "description": "Chebyshev radius of this city's territory. Canon: start/min=1, MaxTerritoryRadius=5."
          },
          "territory_tile_indices": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 6399
            }
          }
        }
      }
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "unit_id",
          "unit_type_id",
          "owner_player_id",
          "x",
          "y",
          "hp",
          "kills_in_chain",
          "kill_count_total",
          "veterancy_level",
          "has_acted_this_turn"
        ],
        "properties": {
          "unit_id": {
            "type": "string"
          },
          "unit_type_id": {
            "type": "string"
          },
          "owner_player_id": {
            "type": "string"
          },
          "x": {
            "type": "integer",
            "minimum": 0,
            "maximum": 79
          },
          "y": {
            "type": "integer",
            "minimum": 0,
            "maximum": 79
          },
          "hp": {
            "type": "integer",
            "minimum": 0
          },
          "kills_in_chain": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "kill_count_total": {
            "type": "integer",
            "minimum": 0
          },
          "veterancy_level": {
            "type": "integer",
            "minimum": 0
          },
          "has_acted_this_turn": {
            "type": "boolean",
            "default": false,
            "description": "Per-unit per-turn action flag. True after the unit performs its single action for the turn (move, attack, heal, disband, special). Replaces legacy has_moved/has_attacked."
          },
          "garrisoned_city_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "diplomacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relations"
      ],
      "properties": {
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "a_player_id",
              "b_player_id",
              "state",
              "min_alliance_turns_left",
              "cooldown_turns_left"
            ],
            "properties": {
              "a_player_id": {
                "type": "string"
              },
              "b_player_id": {
                "type": "string"
              },
              "state": {
                "type": "string",
                "enum": [
                  "WAR",
                  "NEUTRAL",
                  "ALLIANCE"
                ]
              },
              "min_alliance_turns_left": {
                "type": "integer",
                "minimum": 0,
                "maximum": 6
              },
              "cooldown_turns_left": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3
              }
            }
          }
        }
      }
    },
    "victory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "global_city_power",
        "per_player"
      ],
      "properties": {
        "global_city_power": {
          "type": "integer",
          "minimum": 0
        },
        "per_player": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "player_id",
              "military_city_power",
              "economic_hold_turns_left",
              "tech_victory_turns_left",
              "won",
              "lost"
            ],
            "properties": {
              "player_id": {
                "type": "string"
              },
              "military_city_power": {
                "type": "integer",
                "minimum": 0
              },
              "economic_hold_turns_left": {
                "type": "integer",
                "minimum": 0,
                "maximum": 5
              },
              "tech_victory_turns_left": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10
              },
              "won": {
                "type": "boolean"
              },
              "lost": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "description": "Replay-log. Discriminated union by event_type (v4.28). Canon: docs/01_overview/Action_Catalog.md",
      "items": { "$ref": "#/$defs/GameEvent" }
    }
  },
  "$defs": {
    "GameEvent": {
      "oneOf": [
        { "$ref": "#/$defs/Event_MOVE" },
        { "$ref": "#/$defs/Event_ATTACK" },
        { "$ref": "#/$defs/Event_SERIAL_ATTACK" },
        { "$ref": "#/$defs/Event_HEAL" },
        { "$ref": "#/$defs/Event_DISBAND" },
        { "$ref": "#/$defs/Event_CAPTURE_CITY" },
        { "$ref": "#/$defs/Event_PRODUCE" },
        { "$ref": "#/$defs/Event_BUILD_ROAD" },
        { "$ref": "#/$defs/Event_UPGRADE_ROAD" },
        { "$ref": "#/$defs/Event_BUILD_PORT" },
        { "$ref": "#/$defs/Event_UPGRADE_PORT" },
        { "$ref": "#/$defs/Event_UPGRADE_CITY" },
        { "$ref": "#/$defs/Event_BOOST_SCIENCE" },
        { "$ref": "#/$defs/Event_BOOST_STABILITY" },
        { "$ref": "#/$defs/Event_START_HARVEST" },
        { "$ref": "#/$defs/Event_REPAIR_ROAD" },
        { "$ref": "#/$defs/Event_CYBER_DISRUPT" },
        { "$ref": "#/$defs/Event_CYBER_DAMAGE_ROAD" },
        { "$ref": "#/$defs/Event_TECH_UNLOCK" },
        { "$ref": "#/$defs/Event_DECLARE_WAR" },
        { "$ref": "#/$defs/Event_MAKE_PEACE" },
        { "$ref": "#/$defs/Event_FORM_ALLIANCE" },
        { "$ref": "#/$defs/Event_BREAK_ALLIANCE" },
        { "$ref": "#/$defs/Event_REBELLION" },
        { "$ref": "#/$defs/Event_ELIMINATION" },
        { "$ref": "#/$defs/Event_VICTORY_TRIGGER" },
        { "$ref": "#/$defs/Event_VICTORY_COMPLETE" },
        { "$ref": "#/$defs/Event_HIDDEN_CIV_SPAWN" }
      ]
    },
    "EventBase": {
      "type": "object",
      "required": ["event_id", "round_index", "civ_turn_index", "acting_civ_id", "event_type", "payload"],
      "additionalProperties": false,
      "properties": {
        "event_id": { "type": "string" },
        "round_index": { "type": "integer", "minimum": 0, "description": "Round number; increments after all alive civs complete a turn" },
        "civ_turn_index": { "type": "integer", "minimum": 0, "description": "Flat turn counter; same as match.turn.turn_index" },
        "turn_index": { "type": "integer", "minimum": 0, "description": "Deprecated: use civ_turn_index" },
        "acting_civ_id": { "type": "integer", "minimum": 0, "maximum": 9 },
        "event_type": { "type": "string" },
        "seq": { "type": "integer", "minimum": 0, "description": "Order within civ turn" },
        "payload": { "type": "object" }
      }
    },
    "Event_MOVE": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "MOVE" }, "payload": { "$ref": "#/$defs/Payload_MOVE" } }, "required": ["event_type", "payload"] }] },
    "Payload_MOVE": { "type": "object", "additionalProperties": false, "required": ["unit_id", "from_tile", "to_tile"], "properties": { "unit_id": { "type": "string" }, "from_tile": { "type": "integer", "minimum": 0, "maximum": 6399 }, "to_tile": { "type": "integer", "minimum": 0, "maximum": 6399 } } },
    "Event_ATTACK": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "ATTACK" }, "payload": { "$ref": "#/$defs/Payload_ATTACK" } }, "required": ["event_type", "payload"] }] },
    "Payload_ATTACK": { "type": "object", "additionalProperties": false, "required": ["attacker_unit_id", "target_unit_id", "damage", "target_remaining_hp"], "properties": { "attacker_unit_id": { "type": "string" }, "target_unit_id": { "type": "string" }, "damage": { "type": "integer", "minimum": 0 }, "target_remaining_hp": { "type": "integer", "minimum": 0 }, "counterattack_damage": { "type": "integer", "minimum": 0 }, "attacker_destroyed": { "type": "boolean" } } },
    "Event_SERIAL_ATTACK": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "SERIAL_ATTACK" }, "payload": { "$ref": "#/$defs/Payload_SERIAL_ATTACK" } }, "required": ["event_type", "payload"] }] },
    "Payload_SERIAL_ATTACK": { "type": "object", "additionalProperties": false, "required": ["attacker_unit_id", "chain_index", "target_unit_id", "damage", "target_destroyed"], "properties": { "attacker_unit_id": { "type": "string" }, "chain_index": { "type": "integer", "minimum": 0 }, "target_unit_id": { "type": "string" }, "damage": { "type": "integer", "minimum": 0 }, "target_destroyed": { "type": "boolean" } } },
    "Event_HEAL": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "HEAL" }, "payload": { "$ref": "#/$defs/Payload_HEAL" } }, "required": ["event_type", "payload"] }] },
    "Payload_HEAL": { "type": "object", "additionalProperties": false, "required": ["unit_id", "hp_before", "hp_after"], "properties": { "unit_id": { "type": "string" }, "hp_before": { "type": "integer", "minimum": 0 }, "hp_after": { "type": "integer", "minimum": 0 } } },
    "Event_DISBAND": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "DISBAND" }, "payload": { "$ref": "#/$defs/Payload_DISBAND" } }, "required": ["event_type", "payload"] }] },
    "Payload_DISBAND": { "type": "object", "additionalProperties": false, "required": ["unit_id", "ap_refund"], "properties": { "unit_id": { "type": "string" }, "ap_refund": { "type": "integer", "minimum": 0 } } },
    "Event_CAPTURE_CITY": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "CAPTURE_CITY" }, "payload": { "$ref": "#/$defs/Payload_CAPTURE_CITY" } }, "required": ["event_type", "payload"] }] },
    "Payload_CAPTURE_CITY": { "type": "object", "additionalProperties": false, "required": ["unit_id", "city_id"], "properties": { "unit_id": { "type": "string" }, "city_id": { "type": "string" }, "from_owner_civ_id": { "type": "integer" }, "to_owner_civ_id": { "type": "integer" }, "integration_turns_left": { "type": "integer", "minimum": 0, "maximum": 4 } } },
    "Event_PRODUCE": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "PRODUCE" }, "payload": { "$ref": "#/$defs/Payload_PRODUCE" } }, "required": ["event_type", "payload"] }] },
    "Payload_PRODUCE": { "type": "object", "additionalProperties": false, "required": ["city_id", "unit_type_id", "spawned_unit_id"], "properties": { "city_id": { "type": "string" }, "unit_type_id": { "type": "string" }, "spawned_unit_id": { "type": "string" } } },
    "Event_BUILD_ROAD": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "BUILD_ROAD" }, "payload": { "$ref": "#/$defs/Payload_BUILD_ROAD" } }, "required": ["event_type", "payload"] }] },
    "Payload_BUILD_ROAD": { "type": "object", "additionalProperties": false, "required": ["tile_id", "new_road_level"], "properties": { "tile_id": { "type": "integer", "minimum": 0, "maximum": 6399 }, "new_road_level": { "type": "integer", "minimum": 1, "maximum": 3 } } },
    "Event_UPGRADE_ROAD": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "UPGRADE_ROAD" }, "payload": { "$ref": "#/$defs/Payload_UPGRADE_ROAD" } }, "required": ["event_type", "payload"] }] },
    "Payload_UPGRADE_ROAD": { "type": "object", "additionalProperties": false, "required": ["tile_id", "new_road_level"], "properties": { "tile_id": { "type": "integer", "minimum": 0, "maximum": 6399 }, "old_road_level": { "type": "integer", "minimum": 1, "maximum": 2 }, "new_road_level": { "type": "integer", "minimum": 2, "maximum": 3 } } },
    "Event_BUILD_PORT": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "BUILD_PORT" }, "payload": { "$ref": "#/$defs/Payload_BUILD_PORT" } }, "required": ["event_type", "payload"] }] },
    "Payload_BUILD_PORT": { "type": "object", "additionalProperties": false, "required": ["tile_id", "new_port_level"], "properties": { "tile_id": { "type": "integer", "minimum": 0, "maximum": 6399 }, "new_port_level": { "type": "integer", "minimum": 1, "maximum": 3 } } },
    "Event_UPGRADE_PORT": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "UPGRADE_PORT" }, "payload": { "$ref": "#/$defs/Payload_UPGRADE_PORT" } }, "required": ["event_type", "payload"] }] },
    "Payload_UPGRADE_PORT": { "type": "object", "additionalProperties": false, "required": ["tile_id", "new_port_level"], "properties": { "tile_id": { "type": "integer", "minimum": 0, "maximum": 6399 }, "old_port_level": { "type": "integer", "minimum": 1, "maximum": 2 }, "new_port_level": { "type": "integer", "minimum": 2, "maximum": 3 } } },
    "Event_UPGRADE_CITY": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "UPGRADE_CITY" }, "payload": { "$ref": "#/$defs/Payload_UPGRADE_CITY" } }, "required": ["event_type", "payload"] }] },
    "Payload_UPGRADE_CITY": { "type": "object", "additionalProperties": false, "required": ["city_id", "new_city_level", "chosen_reward"], "properties": { "city_id": { "type": "string" }, "new_city_level": { "type": "integer", "minimum": 2, "maximum": 5 }, "chosen_reward": { "type": "string", "enum": ["DEFENSE", "EXPAND_TERRITORY", "UNLOCK_PORT", "SPECIALIZATION"] } } },
    "Event_BOOST_SCIENCE": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "BOOST_SCIENCE" }, "payload": { "$ref": "#/$defs/Payload_BOOST_SCIENCE" } }, "required": ["event_type", "payload"] }] },
    "Payload_BOOST_SCIENCE": { "type": "object", "additionalProperties": false, "required": ["money_spent", "science_gained"], "properties": { "money_spent": { "type": "integer", "minimum": 0 }, "science_gained": { "type": "integer", "minimum": 0 }, "cap_used": { "type": "integer", "minimum": 0 } } },
    "Event_BOOST_STABILITY": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "BOOST_STABILITY" }, "payload": { "$ref": "#/$defs/Payload_BOOST_STABILITY" } }, "required": ["event_type", "payload"] }] },
    "Payload_BOOST_STABILITY": { "type": "object", "additionalProperties": false, "required": ["money_spent", "stability_gained"], "properties": { "money_spent": { "type": "integer", "minimum": 0 }, "stability_gained": { "type": "integer", "minimum": 0 } } },
    "Event_START_HARVEST": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "START_HARVEST" }, "payload": { "$ref": "#/$defs/Payload_START_HARVEST" } }, "required": ["event_type", "payload"] }] },
    "Payload_START_HARVEST": { "type": "object", "additionalProperties": false, "required": ["tile_id"], "properties": { "tile_id": { "type": "integer", "minimum": 0, "maximum": 6399 } } },
    "Event_REPAIR_ROAD": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "REPAIR_ROAD" }, "payload": { "$ref": "#/$defs/Payload_REPAIR_ROAD" } }, "required": ["event_type", "payload"] }] },
    "Payload_REPAIR_ROAD": { "type": "object", "additionalProperties": false, "required": ["tile_id"], "properties": { "tile_id": { "type": "integer", "minimum": 0, "maximum": 6399 } } },
    "Event_CYBER_DISRUPT": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "CYBER_DISRUPT" }, "payload": { "$ref": "#/$defs/Payload_CYBER_DISRUPT" } }, "required": ["event_type", "payload"] }] },
    "Payload_CYBER_DISRUPT": { "type": "object", "additionalProperties": false, "required": ["unit_id", "target_city_id"], "properties": { "unit_id": { "type": "string" }, "target_city_id": { "type": "string" }, "disruption_turns": { "type": "integer", "minimum": 2, "maximum": 2 } } },
    "Event_CYBER_DAMAGE_ROAD": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "CYBER_DAMAGE_ROAD" }, "payload": { "$ref": "#/$defs/Payload_CYBER_DAMAGE_ROAD" } }, "required": ["event_type", "payload"] }] },
    "Payload_CYBER_DAMAGE_ROAD": { "type": "object", "additionalProperties": false, "required": ["unit_id", "target_tile_index"], "properties": { "unit_id": { "type": "string" }, "target_tile_index": { "type": "integer", "minimum": 0, "maximum": 6399 }, "road_damaged_turns": { "type": "integer", "minimum": 2, "maximum": 2 } } },
    "Event_TECH_UNLOCK": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "TECH_UNLOCK" }, "payload": { "$ref": "#/$defs/Payload_TECH_UNLOCK" } }, "required": ["event_type", "payload"] }] },
    "Payload_TECH_UNLOCK": { "type": "object", "additionalProperties": false, "required": ["branch", "level"], "properties": { "branch": { "type": "string", "enum": ["MILITARY", "ECONOMIC", "SCIENCE"] }, "level": { "type": "integer", "minimum": 1, "maximum": 5 } } },
    "Event_DECLARE_WAR": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "DECLARE_WAR" }, "payload": { "$ref": "#/$defs/Payload_DECLARE_WAR" } }, "required": ["event_type", "payload"] }] },
    "Payload_DECLARE_WAR": { "type": "object", "additionalProperties": false, "required": ["from_civ_id", "to_civ_id"], "properties": { "from_civ_id": { "type": "integer", "minimum": 0, "maximum": 9 }, "to_civ_id": { "type": "integer", "minimum": 0, "maximum": 9 } } },
    "Event_MAKE_PEACE": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "MAKE_PEACE" }, "payload": { "$ref": "#/$defs/Payload_MAKE_PEACE" } }, "required": ["event_type", "payload"] }] },
    "Payload_MAKE_PEACE": { "type": "object", "additionalProperties": false, "required": ["from_civ_id", "to_civ_id"], "properties": { "from_civ_id": { "type": "integer", "minimum": 0, "maximum": 9 }, "to_civ_id": { "type": "integer", "minimum": 0, "maximum": 9 } } },
    "Event_FORM_ALLIANCE": { "allOf": [{ "$ref": "#/$defs/EventBase" }, { "properties": { "event_type": { "const": "FORM_ALLIANCE" }, "payload": { "$ref": "#/$defs/Payload_FORM_ALLIANCE" } }, "required": ["event_type", "payload"] }] },
